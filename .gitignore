# ─── Rust / Cargo ────────────────────────────────────────────────────────────
/target/
**/target/
**/*.rs.bk
*.pdb

# ─── NAPI / native addon build artifacts ────────────────────────────────────
# The compiled .node binary is a build artifact that gets regenerated by
# `napi build`.  Platform-specific prebuilds are published as separate npm
# packages (fals3-darwin-arm64, fals3-linux-x64-gnu, ...), not committed here.
npm/*.node
npm/*.dylib
npm/*.so
npm/*.dll

# ─── Node ───────────────────────────────────────────────────────────────────
node_modules/
.npm/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Lockfiles: keep package-lock.json in npm/ so consumers see pinned dev deps,
# but ignore stray ones at other levels.
/package-lock.json
/yarn.lock
/pnpm-lock.yaml

# Vitest / coverage
coverage/
.vitest-cache/
.nyc_output/

# TypeScript build cache (we don't compile TS to JS here, but tooling still leaks files)
*.tsbuildinfo

# ─── Tooling caches ─────────────────────────────────────────────────────────
.nx/cache/
.nx/workspace-data/
.cargo/

# ─── IDE / editor ───────────────────────────────────────────────────────────
.idea/
*.iml
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
!.vscode/launch.json
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ─── Local env / secrets ────────────────────────────────────────────────────
.env
.env.*
!.env.example

# ─── Issue tracker (kept in case bd is reintroduced; otherwise harmless) ────
.dolt/
*.db

# ─── Misc test scratch ──────────────────────────────────────────────────────
# Default fals3 test base dirs if a test forgets to use a temp directory.
/tmp/fals3-*
fals3-test-data/
