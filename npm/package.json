{
  "name": "fals3",
  "version": "0.1.0",
  "description": "S3 behavioral simulator for local testing — Rust core, NAPI-RS native addon",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "main": "index.js",
  "types": "index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "require": "./index.js",
      "import": "./index.js"
    },
    "./helpers": {
      "types": "./helpers.d.ts",
      "require": "./helpers.js",
      "import": "./helpers.js"
    },
    "./sdk-shim": {
      "types": "./sdk-shim.d.ts",
      "require": "./sdk-shim.js",
      "import": "./sdk-shim.js"
    }
  },
  "files": [
    "index.js",
    "index.d.ts",
    "helpers.js",
    "helpers.d.ts",
    "sdk-shim.js",
    "sdk-shim.d.ts",
    "README.md",
    "*.node"
  ],
  "optionalDependencies": {
    "fals3-darwin-arm64": "0.1.0",
    "fals3-linux-x64-gnu": "0.1.0",
    "fals3-win32-x64-msvc": "0.1.0"
  },
  "devDependencies": {
    "vitest": "^2.0.0",
    "typescript": "^5.0.0"
  },
  "scripts": {
    "build": "napi build --platform --release",
    "build:debug": "napi build --platform",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "s3",
    "mock",
    "simulator",
    "testing",
    "aws",
    "napi"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/fals3/fals3"
  }
}
